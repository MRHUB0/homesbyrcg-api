{
  "name": "homesbyrcg-api",
  "version": "0.1.0",
  "description": "Enterprise serverless backend foundation for Homes by RCG.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test",
    "validate": "npm run lint && npm run format:check && npm test",
    "build": "find src tests -name \"*.js\" -print0 | xargs -0 -n1 node --check",
    "sam-build": "sam build",
    "sam-local": "sam local start-api",
    "sam-deploy": "sam deploy --guided"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1080.0",
    "@aws-sdk/client-ses": "^3.1079.0"
  }
}
